# VilfinTV — Local Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and MUST NEVER be committed.
#
# The WORKER_URL is the ONLY secret needed locally.
# In GitHub Actions it is stored as a repository Secret (Settings → Secrets).
# ─────────────────────────────────────────────────────────────────────

# Your Cloudflare Worker URL (no trailing slash)
# Found in: Cloudflare Dashboard → Workers & Pages → your worker → Settings → Triggers
WORKER_URL=https://your-worker-name.workers.dev
