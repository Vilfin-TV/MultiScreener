# Copy this file to `wrangler.toml` and replace YOUR-WORKER-NAME
# with your actual worker name (visible in the Cloudflare dashboard URL,
# e.g. https://dash.cloudflare.com/.../workers-and-pages/view/YOUR-WORKER-NAME).
#
# Then deploy with:
#   npx wrangler deploy

name = "YOUR-WORKER-NAME"
main = "worker.js"
compatibility_date = "2024-12-01"

# Secrets (API keys) are NOT stored here — they're set via:
#   npx wrangler secret put GROQ_API_KEY
#   npx wrangler secret put GEMINI_API_KEY
#   npx wrangler secret put OPENAI_API_KEY
#   npx wrangler secret put DEEPSEEK_API_KEY

# Optional: pin to specific account if you have multiple Cloudflare accounts
# account_id = "your-account-id"

# Optional: custom route (otherwise uses *.workers.dev subdomain)
# route = "api.yourdomain.com/*"
